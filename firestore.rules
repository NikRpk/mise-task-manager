rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========== HELPER FUNCTIONS ==========
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserId() {
      return request.auth.uid;
    }
    
    // ========== PROJECTS ==========
    match /projects/{projectId} {
      // Anyone authenticated can create a project
      // Must set createdBy to their own UID
      // Must include themselves as ADMIN in members array
      allow create: if isAuthenticated() 
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.members is list
        && request.resource.data.members.size() > 0;
      
      // For read/update/delete: We rely on backend enforcement due to 
      // Firestore Rules limitations with array searching.
      // Basic check: must be authenticated
      // TODO: Consider migrating members to a map structure for better security rules
      allow read, update, delete: if isAuthenticated();
    }
    
    // ========== TASKS ==========
    match /tasks/{taskId} {
      // Can create if authenticated and projectId is set
      // Backend will verify project membership
      allow create: if isAuthenticated() 
        && request.resource.data.projectId != null
        && request.resource.data.projectId is string;
      
      // Can read/update/delete if authenticated
      // Backend will verify project membership and roles
      allow read, update, delete: if isAuthenticated();
      
      // Prevent changing projectId on update
      allow update: if request.resource.data.projectId == resource.data.projectId;
    }
    
    // ========== USER SETTINGS ==========
    match /userSettings/{userId} {
      // Users can only read/write their own settings
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // ========== NOTES ==========
    match /notes/{noteId} {
      // Users can only create their own notes
      allow create: if isAuthenticated() 
        && request.resource.data.createdBy == request.auth.uid;
      
      // Users can only read their own notes
      allow read: if isAuthenticated() 
        && resource.data.createdBy == request.auth.uid;
      
      // Users can only update their own notes
      // Prevent changing owner
      allow update: if isAuthenticated() 
        && resource.data.createdBy == request.auth.uid
        && request.resource.data.createdBy == resource.data.createdBy;
      
      // Users can only delete their own notes
      allow delete: if isAuthenticated() 
        && resource.data.createdBy == request.auth.uid;
    }
    
    // ========== NOTE TEMPLATES ==========
    match /noteTemplates/{templateId} {
      // Users can only create their own templates
      allow create: if isAuthenticated() 
        && request.resource.data.createdBy == request.auth.uid;
      
      // Users can only read their own templates
      allow read: if isAuthenticated() 
        && resource.data.createdBy == request.auth.uid;
      
      // Users can only update their own templates
      // Prevent changing owner
      allow update: if isAuthenticated() 
        && resource.data.createdBy == request.auth.uid
        && request.resource.data.createdBy == resource.data.createdBy;
      
      // Users can only delete their own templates
      allow delete: if isAuthenticated() 
        && resource.data.createdBy == request.auth.uid;
    }
    
    // ========== PEOPLE/CONTACTS ==========
    match /people/{personId} {
      // All authenticated users can read the people database
      allow read: if isAuthenticated();
      
      // Only backend can write (through admin SDK)
      allow write: if false;
    }
    
    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
