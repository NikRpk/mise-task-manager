rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to get user ID
    function getUserId() {
      return request.auth.uid;
    }
    
    // ========== PROJECTS ==========
    match /projects/{projectId} {
      // Anyone authenticated can create a project
      allow create: if isAuthenticated();
      
      // Read/update/delete - complex member checks happen in backend
      // Allow if user is authenticated (backend will enforce member checks)
      allow read, update, delete: if isAuthenticated();
    }
    
    // ========== TASKS ==========
    match /tasks/{taskId} {
      // All operations allowed if authenticated (backend enforces project membership)
      allow create, read, update, delete: if isAuthenticated();
    }
    
    // ========== USER SETTINGS ==========
    match /userSettings/{userId} {
      // Users can only read/write their own settings
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // ========== NOTES ==========
    // Notes can include: title, content, tasks, calendarEventId, calendarEventLink,
    // calendarEventData, googleDocId, googleDocUrl, recurringEventId, recurringInstanceDate,
    // templateId, createdBy, createdAt, updatedAt
    match /notes/{noteId} {
      // Users can only create their own notes
      allow create: if isAuthenticated() && request.resource.data.createdBy == request.auth.uid;
      
      // Users can only read their own notes
      allow read: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
      
      // Users can only update their own notes
      allow update: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
      
      // Users can only delete their own notes
      allow delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }
    
    // ========== NOTE TEMPLATES ==========
    match /noteTemplates/{templateId} {
      // Users can only create their own templates
      allow create: if isAuthenticated() && request.resource.data.createdBy == request.auth.uid;
      
      // Users can only read their own templates
      allow read: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
      
      // Users can only update their own templates
      allow update: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
      
      // Users can only delete their own templates
      allow delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }
    
    // ========== PEOPLE/CONTACTS ==========
    match /people/{personId} {
      // All authenticated users can read the people database
      allow read: if isAuthenticated();
      
      // Only backend can write (through admin SDK)
      allow write: if false;
    }
    
    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
